(provide :eval-arithmetic-types)

(define-test "Arithmetic"
;;; Arithmetic

(check (= (+ 1 2 3) 6) "addition")
(check (= (- 7) -7) "unary subtraction")
(check (= (* 4 5) 20) "multiplication")
(check (= (/ 20 2 2) 5) "division")
(check (= (+ 1.5 2) 3.5) "mixed addition returns float")
(check (= (/ 5.0 2) 2.5) "mixed division returns float")
(check (= (- 1.5) -1.5) "unary subtraction on float")
(check (eq? (type-of (/ 5 2)) SmallFraction) "integer division returns fraction")
(check (= (/ 5 2) 5/2) "integer division remains exact")
(check (eq? (type-of (+ 340282366920938463463374607431768211456 1)) BigInteger)
       "overflow promotes to big integer")
(check (= (+ 340282366920938463463374607431768211456 1)
          340282366920938463463374607431768211457)
       "big integer value")
(check (= (+ 1/2 1/3) 5/6) "fraction addition stays reduced")
(check (= (* 18446744073709551616 18446744073709551616)
          340282366920938463463374607431768211456)
       "large multiplication value")
(check (= (+ 1+2i 3+4i) 4+6i) "complex addition")
(check (= (* 1+2i 3+4i) -5+10i) "complex multiplication")
(check (= (* (/ 1+2i 3+4i) 3+4i) 1+2i) "complex division round-trip")
(check (= (+ 2 1+3i) 3+3i) "real and complex mixed addition")
(check (= (slot-ref 1+2i 'real) 1) "ExactComplexNumber real slot")
(check (= (slot-ref 1+2i 'imaginary) 2) "ExactComplexNumber imaginary slot")
(check (= [1+2i real] 1) "ExactComplexNumber>>real")
(check (= [1+2i imaginary] 2) "ExactComplexNumber>>imaginary")
(check (= (* 2 3/2) 3) "fraction multiplication canonicalizes to integer")
(check-near pi 3.141592653589793 1e-15 "pi constant")
(check-near (sin (/ pi 2)) 1.0 1e-12 "sin primitive")
(check-near (cos pi) -1.0 1e-12 "cos primitive")
(check-near (tan 0) 0.0 1e-12 "tan primitive")
(check (= (abs -5/2) 5/2) "abs preserves exact real magnitude")
(check-near (abs -2.5) 2.5 1e-12 "abs handles floats")
(check-near (abs 3+4i) 5.0 1e-12 "abs handles complex numbers")
(check-near (phase 2) 0.0 1e-12 "phase of positive real")
(check-near (phase -2) pi 1e-12 "phase of negative real")
(check-near (phase 0+1i) (/ pi 2) 1e-12 "phase of complex number")
(check-near (sqrt 4) 2.0 1e-12 "sqrt positive real")
(let ((z (sqrt -4)))
  (check-near (slot-ref z 'real) 0.0 1e-12 "sqrt negative real has zero real part")
  (check-near (slot-ref z 'imaginary) 2.0 1e-12 "sqrt negative real has positive imaginary part"))
(let ((z (sqrt 3+4i)))
  (check-near (slot-ref z 'real) 2.0 1e-12 "sqrt complex real part")
  (check-near (slot-ref z 'imaginary) 1.0 1e-12 "sqrt complex imaginary part"))
(check (= (min 4 2 7/3 3.5) 2) "min primitive")
(check (= (max 4 2 7/3 3.5) 4) "max primitive")
(check (= [2 compareWith: 3] -1) "Number>>compareWith: returns -1 for less")
(check (= [3 compareWith: 3] 0) "Number>>compareWith: returns 0 for equal")
(check (= [4 compareWith: 3] 1) "Number>>compareWith: returns 1 for greater")
(check-raises "min rejects complex numbers" (min 1 1+1i))
(check-raises "max rejects complex numbers" (max 1 1+1i))
(check (zero? 0+0i) "zero? accepts complex zero")
(check (not (zero? 0+1i)) "zero? false for non-zero complex")
(check (positive? 1/2) "positive? true")
(check (negative? -1/2) "negative? true")
(check (not (positive? 0)) "positive? false for zero")
(check (not (negative? 0)) "negative? false for zero")
(check-raises "positive? rejects complex numbers" (positive? 1+1i))
(check-raises "negative? rejects complex numbers" (negative? 1+1i))
(check (= (floor 5/2) 2) "floor positive exact fraction")
(check (= (floor -5/2) -3) "floor negative exact fraction")
(check (= (truncate 5/2) 2) "truncate positive exact fraction")
(check (= (truncate -5/2) -2) "truncate negative exact fraction")
(check (= (ceiling 5/2) 3) "ceiling positive exact fraction")
(check (= (ceiling -5/2) -2) "ceiling negative exact fraction")
(check (= (round 5/2) 3) "round positive exact half away from zero")
(check (= (round -5/2) -3) "round negative exact half away from zero")
(check (= (round 7/3) 2) "round exact fraction below half")
(check (= (floor 340282366920938463463374607431768211457/2)
          170141183460469231731687303715884105728)
       "floor exact big fraction")
(check (= (ceiling 340282366920938463463374607431768211457/2)
          170141183460469231731687303715884105729)
       "ceiling exact big fraction")
(check (= (floor -2.5) -3) "floor float returns integer")
(check (= (truncate -2.5) -2) "truncate float returns integer")
(check (= (ceiling -2.5) -2) "ceiling float returns integer")
(check (= (round -2.5) -3) "round float half away from zero")
(check-raises "floor rejects complex numbers" (floor 1+1i))
(check-raises "truncate rejects complex numbers" (truncate 1+1i))
(check-raises "ceiling rejects complex numbers" (ceiling 1+1i))
(check-raises "round rejects complex numbers" (round 1+1i))
(check-near (log (expt 2)) 2.0 1e-12 "log primitive")
(check-near (expt) 2.718281828459045 1e-15 "expt zero-argument returns e")
(check-near (expt 2) 7.38905609893065 1e-12 "expt one-argument returns e^x")
(check (= (expt 2 10) 1024) "expt with integer exponent stays exact")
(check (= (expt 1+1i 2) 0+2i) "expt supports complex base with integer exponent")
(check (eq? (type-of (sin 1+1i)) InexactComplexNumber) "sin accepts complex numbers")
(check (eq? (type-of (log -1)) InexactComplexNumber) "log promotes negative real to complex")
(check (eq? (type-of (expt -1 1/2)) InexactComplexNumber)
       "expt promotes negative base with non-integer exponent to complex")
(check (eq? (type-of (expt 2 1+1i)) InexactComplexNumber)
       "expt accepts complex exponent")
(let ((z (sin 1+1i)))
  (check-near (slot-ref z 'real) 1.2984575814159773 1e-12
              "InexactComplexNumber real slot")
  (check-near (slot-ref z 'imaginary) 0.6349639147847361 1e-12
              "InexactComplexNumber imaginary slot")
  (check-near [z real] 1.2984575814159773 1e-12
              "InexactComplexNumber>>real")
  (check-near [z imaginary] 0.6349639147847361 1e-12
              "InexactComplexNumber>>imaginary"))
)

(define-test "Symbols and keywords"
;;; Symbols and keywords

(check (primitive? +) "symbol lookup in base environment")
(check (symbol? :token) "keyword eval result is symbol")
(check (eq? :token :token) "keyword is self-evaluating and interned")
)

(define-test "display"
;;; display

(check (equal? (display "hello") "hello") "display returns exact string argument")
)

(define-test "type-of, class?, type predicates"
;;; type-of, class?, type predicates

(check (eq? (type-of 1) SmallInteger) "type-of returns class object")
(check (class? SmallInteger) "SmallInteger is a class")
(check (class? Pair) "Pair is a class")
(check (class? String) "String is a class")
(check (number? 1) "number? true for fixnum")
(check (number? 1/2) "number? true for fraction")
(check (number? 1+2i) "number? true for complex")
(check (not (number? "x")) "number? false for string")
(check (complex? 1+2i) "complex? true for complex")
(check (complex? 1) "complex? true for real numbers")
(check (real? 1/2) "real? true for rationals")
(check (real? 1.0) "real? true for floats")
(check (not (real? 1+2i)) "real? false for complex with imaginary part")
(check (rational? 1/2) "rational? true for fractions")
(check (not (rational? 1.0)) "rational? false for floats")
(check (integer? 42) "integer? true for integers")
(check (integer? 340282366920938463463374607431768211456)
       "integer? true for big integers")
(check (not (integer? 1/2)) "integer? false for fractions")
(check (null? '()) "null? true for nil")
(check (not (null? 1)) "null? false for non-nil")
(check (boolean? #true) "boolean? true for #true")
(check (boolean? #false) "boolean? false for #false")
(check (not (boolean? 1)) "boolean? false for non-boolean")
(check (symbol? 'foo) "symbol? true for symbol")
(check (not (symbol? 1)) "symbol? false for non-symbol")
(check (keyword? :foo) "keyword? true for keyword symbol")
(check (not (keyword? 'foo)) "keyword? false for non-keyword symbol")
(check (not (keyword? 1)) "keyword? false for non-symbol")
(check (function? +) "function? true for primitive")
(check (function? (lambda (x) x)) "function? true for closure")
(check (not (function? (macro (lambda (x) x))))
       "function? false for macro")
(check (not (function? if)) "function? false for special form")
(check (not (function? 1)) "function? false for non-function")
)

(define-test "number->string"
;;; number->string

(check (equal? (number->string 42) "42") "number->string integer")
(check (equal? (number->string 1/2) "1/2") "number->string fraction")
(check (equal? (number->string 3.5) "3.5") "number->string float")
(check (equal? (number->string (+ 340282366920938463463374607431768211456 1))
               "340282366920938463463374607431768211457")
       "number->string big integer")
(check-raises "number->string type error on non-number"
  (number->string "not a number"))
)
