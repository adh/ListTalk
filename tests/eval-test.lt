(load! :os)

;;; Test framework

(define test-failures 0)

(define (check condition description)
  (if condition
      #true
      (begin
        (set! test-failures (+ test-failures 1))
        (display (string-append "FAIL: " description))
        #false)))

(define (check-near actual expected epsilon description)
  (check (and (<= (- actual expected) epsilon)
              (<= (- expected actual) epsilon))
         description))

(define (raises? thunk)
  (catch :raises-check
    (handler-bind (lambda (c) (throw :raises-check c))
      (thunk)
      #false)))

(define-macro (check-raises description . body)
  `(check (raises? (lambda () ,@body)) ,description))

(define-macro (check-error-message message description . body)
  `(let ((c (raises? (lambda () ,@body))))
     (check (and c (equal? (slot-ref c 'message) ,message)) ,description)))

;;; Arithmetic

(check (= (+ 1 2 3) 6) "addition")
(check (= (- 7) -7) "unary subtraction")
(check (= (* 4 5) 20) "multiplication")
(check (= (/ 20 2 2) 5) "division")
(check (= (+ 1.5 2) 3.5) "mixed addition returns float")
(check (= (/ 5.0 2) 2.5) "mixed division returns float")
(check (= (- 1.5) -1.5) "unary subtraction on float")
(check (eq? (type-of (/ 5 2)) SmallFraction) "integer division returns fraction")
(check (= (/ 5 2) 5/2) "integer division remains exact")
(check (eq? (type-of (+ 340282366920938463463374607431768211456 1)) BigInteger)
       "overflow promotes to big integer")
(check (= (+ 340282366920938463463374607431768211456 1)
          340282366920938463463374607431768211457)
       "big integer value")
(check (= (+ 1/2 1/3) 5/6) "fraction addition stays reduced")
(check (= (* 18446744073709551616 18446744073709551616)
          340282366920938463463374607431768211456)
       "large multiplication value")
(check (= (+ 1+2i 3+4i) 4+6i) "complex addition")
(check (= (* 1+2i 3+4i) -5+10i) "complex multiplication")
(check (= (* (/ 1+2i 3+4i) 3+4i) 1+2i) "complex division round-trip")
(check (= (+ 2 1+3i) 3+3i) "real and complex mixed addition")
(check (= (slot-ref 1+2i 'real) 1) "ExactComplexNumber real slot")
(check (= (slot-ref 1+2i 'imaginary) 2) "ExactComplexNumber imaginary slot")
(check (= [1+2i real] 1) "ExactComplexNumber>>real")
(check (= [1+2i imaginary] 2) "ExactComplexNumber>>imaginary")
(check (= (* 2 3/2) 3) "fraction multiplication canonicalizes to integer")
(check-near pi 3.141592653589793 1e-15 "pi constant")
(check-near (sin (/ pi 2)) 1.0 1e-12 "sin primitive")
(check-near (cos pi) -1.0 1e-12 "cos primitive")
(check-near (tan 0) 0.0 1e-12 "tan primitive")
(check (= (abs -5/2) 5/2) "abs preserves exact real magnitude")
(check-near (abs -2.5) 2.5 1e-12 "abs handles floats")
(check-near (abs 3+4i) 5.0 1e-12 "abs handles complex numbers")
(check-near (phase 2) 0.0 1e-12 "phase of positive real")
(check-near (phase -2) pi 1e-12 "phase of negative real")
(check-near (phase 0+1i) (/ pi 2) 1e-12 "phase of complex number")
(check-near (sqrt 4) 2.0 1e-12 "sqrt positive real")
(let ((z (sqrt -4)))
  (check-near (slot-ref z 'real) 0.0 1e-12 "sqrt negative real has zero real part")
  (check-near (slot-ref z 'imaginary) 2.0 1e-12 "sqrt negative real has positive imaginary part"))
(let ((z (sqrt 3+4i)))
  (check-near (slot-ref z 'real) 2.0 1e-12 "sqrt complex real part")
  (check-near (slot-ref z 'imaginary) 1.0 1e-12 "sqrt complex imaginary part"))
(check (= (min 4 2 7/3 3.5) 2) "min primitive")
(check (= (max 4 2 7/3 3.5) 4) "max primitive")
(check-raises "min rejects complex numbers" (min 1 1+1i))
(check-raises "max rejects complex numbers" (max 1 1+1i))
(check (zero? 0+0i) "zero? accepts complex zero")
(check (not (zero? 0+1i)) "zero? false for non-zero complex")
(check (positive? 1/2) "positive? true")
(check (negative? -1/2) "negative? true")
(check (not (positive? 0)) "positive? false for zero")
(check (not (negative? 0)) "negative? false for zero")
(check-raises "positive? rejects complex numbers" (positive? 1+1i))
(check-raises "negative? rejects complex numbers" (negative? 1+1i))
(check (= (floor 5/2) 2) "floor positive exact fraction")
(check (= (floor -5/2) -3) "floor negative exact fraction")
(check (= (truncate 5/2) 2) "truncate positive exact fraction")
(check (= (truncate -5/2) -2) "truncate negative exact fraction")
(check (= (ceiling 5/2) 3) "ceiling positive exact fraction")
(check (= (ceiling -5/2) -2) "ceiling negative exact fraction")
(check (= (round 5/2) 3) "round positive exact half away from zero")
(check (= (round -5/2) -3) "round negative exact half away from zero")
(check (= (round 7/3) 2) "round exact fraction below half")
(check (= (floor 340282366920938463463374607431768211457/2)
          170141183460469231731687303715884105728)
       "floor exact big fraction")
(check (= (ceiling 340282366920938463463374607431768211457/2)
          170141183460469231731687303715884105729)
       "ceiling exact big fraction")
(check (= (floor -2.5) -3) "floor float returns integer")
(check (= (truncate -2.5) -2) "truncate float returns integer")
(check (= (ceiling -2.5) -2) "ceiling float returns integer")
(check (= (round -2.5) -3) "round float half away from zero")
(check-raises "floor rejects complex numbers" (floor 1+1i))
(check-raises "truncate rejects complex numbers" (truncate 1+1i))
(check-raises "ceiling rejects complex numbers" (ceiling 1+1i))
(check-raises "round rejects complex numbers" (round 1+1i))
(check-near (log (expt 2)) 2.0 1e-12 "log primitive")
(check-near (expt) 2.718281828459045 1e-15 "expt zero-argument returns e")
(check-near (expt 2) 7.38905609893065 1e-12 "expt one-argument returns e^x")
(check (= (expt 2 10) 1024) "expt with integer exponent stays exact")
(check (= (expt 1+1i 2) 0+2i) "expt supports complex base with integer exponent")
(check (eq? (type-of (sin 1+1i)) InexactComplexNumber) "sin accepts complex numbers")
(check (eq? (type-of (log -1)) InexactComplexNumber) "log promotes negative real to complex")
(check (eq? (type-of (expt -1 1/2)) InexactComplexNumber)
       "expt promotes negative base with non-integer exponent to complex")
(check (eq? (type-of (expt 2 1+1i)) InexactComplexNumber)
       "expt accepts complex exponent")
(let ((z (sin 1+1i)))
  (check-near (slot-ref z 'real) 1.2984575814159773 1e-12
              "InexactComplexNumber real slot")
  (check-near (slot-ref z 'imaginary) 0.6349639147847361 1e-12
              "InexactComplexNumber imaginary slot")
  (check-near [z real] 1.2984575814159773 1e-12
              "InexactComplexNumber>>real")
  (check-near [z imaginary] 0.6349639147847361 1e-12
              "InexactComplexNumber>>imaginary"))

;;; Symbols and keywords

(check (primitive? +) "symbol lookup in base environment")
(check (symbol? :token) "keyword eval result is symbol")
(check (eq? :token :token) "keyword is self-evaluating and interned")

;;; display

(check (equal? (display "hello") "hello") "display returns exact string argument")

;;; type-of, class?, type predicates

(check (eq? (type-of 1) SmallInteger) "type-of returns class object")
(check (class? SmallInteger) "SmallInteger is a class")
(check (class? Pair) "Pair is a class")
(check (class? String) "String is a class")
(check (number? 1) "number? true for fixnum")
(check (number? 1/2) "number? true for fraction")
(check (number? 1+2i) "number? true for complex")
(check (not (number? "x")) "number? false for string")
(check (complex? 1+2i) "complex? true for complex")
(check (complex? 1) "complex? true for real numbers")
(check (real? 1/2) "real? true for rationals")
(check (real? 1.0) "real? true for floats")
(check (not (real? 1+2i)) "real? false for complex with imaginary part")
(check (rational? 1/2) "rational? true for fractions")
(check (not (rational? 1.0)) "rational? false for floats")
(check (integer? 42) "integer? true for integers")
(check (integer? 340282366920938463463374607431768211456)
       "integer? true for big integers")
(check (not (integer? 1/2)) "integer? false for fractions")
(check (null? '()) "null? true for nil")
(check (not (null? 1)) "null? false for non-nil")
(check (boolean? #true) "boolean? true for #true")
(check (boolean? #false) "boolean? false for #false")
(check (not (boolean? 1)) "boolean? false for non-boolean")
(check (symbol? 'foo) "symbol? true for symbol")
(check (not (symbol? 1)) "symbol? false for non-symbol")
(check (keyword? :foo) "keyword? true for keyword symbol")
(check (not (keyword? 'foo)) "keyword? false for non-keyword symbol")
(check (not (keyword? 1)) "keyword? false for non-symbol")

;;; number->string

(check (equal? (number->string 42) "42") "number->string integer")
(check (equal? (number->string 1/2) "1/2") "number->string fraction")
(check (equal? (number->string 3.5) "3.5") "number->string float")
(check (equal? (number->string (+ 340282366920938463463374607431768211456 1))
               "340282366920938463463374607431768211457")
       "number->string big integer")
(check-raises "number->string type error on non-number"
  (number->string "not a number"))

;;; OOP: class methods

(check (eq? [1 class] SmallInteger) "Object>>class returns receiver class")
(check (eq? [Object class] (type-of Object))
       "Object class object inherits Object>>class")
(check (primitive? [Object lookupSelector: :class])
       "Object class object inherits Class method lookup")
(check (eq? [IdentityDictionary class] (type-of IdentityDictionary))
       "early native class object inherits Object>>class")
(check (primitive? [IdentityDictionary lookupSelector: :class])
       "early native class object inherits Class method lookup")
(check (eq? [[ImmutableDictionary new] class] ImmutableDictionary)
       "ImmutableDictionary class>>new returns immutable dictionary")
(check (eq? [[Dictionary new] class] Dictionary)
       "Dictionary class>>new returns dictionary")
(check (eq? [[IdentityDictionary new] class] IdentityDictionary)
       "early native class method dispatch still works")
(check (eq? [WeakKeyIdentityDictionary class] (type-of WeakKeyIdentityDictionary))
       "early native subclass class object inherits Object>>class")
(check (eq? [WeakValueIdentityDictionary class] (type-of WeakValueIdentityDictionary))
       "early native weak value class object inherits Object>>class")
(check (primitive? [Pair lookupSelector: :car]) "Class>>lookupSelector: returns method")
(check (primitive? [Pair >> :car]) "Class>>>> returns direct method")
(check (null? [Pair lookupSelector: :does-not-exist])
       "Class>>lookupSelector: nil for missing selector")
(check (null? [Pair >> :does-not-exist])
       "Class>>>> nil for missing selector")
(check (primitive? [Nil lookupSelector: :length])
       "Nil inherits List>>length")
(check (null? [Nil >> :length])
       "Class>>>> excludes inherited method")
(check (null? [Nil lookupSelector: :car])
       "Nil does not inherit List>>car")
(check [[Pair selectors] contains?: :car] "Class>>selectors contains direct method")
(check (not [[Pair selectors] contains?: :length])
       "Class>>selectors excludes inherited method")
(check [[Pair allSelectors] contains?: :length]
       "Class>>allSelectors contains inherited method")
(check (memq :car [Pair selectorsAsList])
       "Class>>selectorsAsList contains direct method")
(check (memq :length [Pair allSelectorsAsList])
       "Class>>allSelectorsAsList contains inherited method")
(check (memq 'name [Class slots]) "Class>>slots contains name")

(check (class? Message) "Message is a class")

(define-class DNUReceiver (Object) ())
(define-method [DNUReceiver doesNotUnderstand: message]
  (list [message selector]
        [message receiver]
        [message arguments]
        (type-of message)))
(let* ((receiver (make-instance DNUReceiver))
       (handled [receiver missing: 1]))
  (check (and (eq? (car handled) :missing:)
              (eq? (car (cdr handled)) receiver)
              (equal? (car (cdr (cdr handled))) (list 1))
              (eq? (type-of (car (cdr (cdr handled)))) ImmutableList)
              (eq? (car (cdr (cdr (cdr handled)))) Message))
         "not understood send dispatches doesNotUnderstand: with Message"))

;;; OOP: weak references

(let ((reference [WeakReference new: 42]))
  (check [reference alive?] "WeakReference>>alive? true for immediate value")
  (check (= [reference value] 42) "WeakReference>>value returns value")
  [reference value: #false]
  (check (not [reference value]) "WeakReference>>value: updates value"))

(let ((set [WeakIdentitySet new]))
  [set put: 42]
  (check [set contains?: 42] "WeakIdentitySet inherits Set methods"))

(let ((dictionary [IdentityDictionary new])
      (a (cons 1 2))
      (b (cons 1 2))
      (c (cons 1 2)))
  [dictionary at: a put: "a"]
  [dictionary at: b put: "b"]
  (check (= [dictionary size] 2) "IdentityDictionary>>size")
  (check (equal? [dictionary at: a] "a") "IdentityDictionary>>at: returns value")
  (check [dictionary contains?: b] "IdentityDictionary>>contains?: finds key")
  (check (not [dictionary contains?: c])
         "IdentityDictionary>>contains?: rejects equal non-identical key")
  (check (null? [dictionary at: c]) "IdentityDictionary>>at: returns nil for absent key")
  (check (equal? [dictionary remove: a] "a") "IdentityDictionary>>remove: returns value")
  (check (not [dictionary contains?: a]) "IdentityDictionary>>remove: removes key"))

(let ((dictionary [Dictionary newFromAList: '(("a" . 1) ("b" . 2) ("a" . 3))]))
  (check (= [dictionary size] 2) "Dictionary class>>newFromAList: sets size")
  (check (= [dictionary at: "a"] 3)
         "Dictionary class>>newFromAList: uses structural keys")
  (check (= [dictionary at: "b"] 2)
         "Dictionary class>>newFromAList: stores values")
  (check (equal? (assoc "a" [dictionary asAList]) '("a" . 3))
         "Dictionary>>asAList returns associations")
  (check (= [[dictionary map: (lambda (key value) value)] reduce: +] 5)
         "Dictionary>>map: maps key/value pairs")
  (check (let ((sum 0))
           (and (null? [dictionary forEach:
                                   (lambda (key value) (set! sum (+ sum value)))])
                (= sum 5)))
         "Dictionary>>forEach: applies callable to key/value pairs"))

(let ((dictionary [ImmutableDictionary newFromAList:
                   '(("a" . 1) ("b" . 2) ("a" . 3))]))
  (check (= [dictionary size] 2)
         "ImmutableDictionary class>>newFromAList: sets size")
  (check (= [dictionary at: "a"] 3)
         "ImmutableDictionary class>>newFromAList: uses structural keys")
  (check [dictionary contains?: "b"]
         "ImmutableDictionary inherits dictionary lookup protocol")
  (check (equal? (assoc "a" [dictionary asAList]) '("a" . 3))
         "ImmutableDictionary>>asAList returns associations")
  (check (= [[dictionary map: (lambda (key value) value)] reduce: +] 5)
         "ImmutableDictionary>>map: maps key/value pairs"))

(let ((key (list 1)))
  (let ((dictionary [IdentityDictionary newFromAList:
                                      (list (cons key "first")
                                            (cons (list 1) "second")
                                            (cons key "third"))]))
    (check (= [dictionary size] 2)
           "IdentityDictionary class>>newFromAList: uses identity keys")
    (check (equal? [dictionary at: key] "third")
           "IdentityDictionary class>>newFromAList: overwrites identical key")
    (check (equal? (assq key [dictionary asAList]) (cons key "third"))
           "IdentityDictionary>>asAList returns associations")
    (check (= [[dictionary map:
                           (lambda (key value)
                             (if (equal? value "third") 10 1))] reduce: +] 11)
           "IdentityDictionary>>map: maps key/value pairs")
    (check (let ((count 0))
             (and (null? [dictionary forEach:
                                     (lambda (key value)
                                       (set! count (+ count 1)))])
                  (= count 2)))
           "IdentityDictionary>>forEach: applies callable to key/value pairs")))

(let ((dictionary [WeakKeyIdentityDictionary new])
      (key (cons 1 2)))
  [dictionary at: key put: 99]
  (check (= [dictionary at: key] 99)
         "WeakKeyIdentityDictionary inherits IdentityDictionary methods"))

(let ((dictionary [WeakValueIdentityDictionary new])
      (key (cons 3 4)))
  [dictionary at: key put: 100]
  (check (= [dictionary at: key] 100)
         "WeakValueIdentityDictionary inherits IdentityDictionary methods"))

(let ((key (list 2)))
  (let ((dictionary [WeakKeyIdentityDictionary newFromAList:
                                           (list (cons key 8))]))
    (check (= [dictionary at: key] 8)
           "WeakKeyIdentityDictionary class>>newFromAList: stores entries")
    (check (= [[dictionary map: (lambda (key value) value)] car] 8)
           "WeakKeyIdentityDictionary>>map: uses inherited method")))

(let ((key (list 3)))
  (let ((dictionary [WeakValueIdentityDictionary newFromAList:
                                             (list (cons key 9))]))
    (check (= [dictionary at: key] 9)
           "WeakValueIdentityDictionary class>>newFromAList: stores entries")
    (check (= [(assq key [dictionary asAList]) cdr] 9)
           "WeakValueIdentityDictionary>>asAList uses inherited method")))

(let ((variable [DynamicVariable new: "default"]))
  (check (equal? [variable value] "default")
         "DynamicVariable>>value returns default before assignment")
  (check (equal? (ListTalk-implementation:%dynamic-ref variable) "default")
         "ListTalk-implementation:%dynamic-ref returns default before assignment")
  [variable value: "thread-value"]
  (check (equal? [variable value] "thread-value")
         "DynamicVariable>>value: sets current thread value")
  (check (equal? (ListTalk-implementation:%dynamic-ref variable) "thread-value")
         "ListTalk-implementation:%dynamic-ref returns current thread value"))

(let ((|*reader-dynamic-variable*| [DynamicVariable new: "reader-default"]))
  (check (equal? *reader-dynamic-variable* "reader-default")
         "star-delimited symbol reads as dynamic variable reference")
  [|*reader-dynamic-variable*| value: "reader-thread-value"]
  (check (equal? *reader-dynamic-variable* "reader-thread-value")
         "star-delimited symbol reads current dynamic variable value"))

(define *surface-dynamic-variable* "surface-default")
(check (equal? *surface-dynamic-variable* "surface-default")
       "define creates DynamicVariable for star-delimited target")
(set! *surface-dynamic-variable* "surface-thread-value")
(check (equal? *surface-dynamic-variable* "surface-thread-value")
       "set! updates star-delimited dynamic variable target")

(define *dynamic-let-variable* "outer")
(check (equal? (dynamic-let ((*dynamic-let-variable* "inner"))
                *dynamic-let-variable*)
              "inner")
       "dynamic-let binds dynamic variable during body")
(check (equal? *dynamic-let-variable* "outer")
       "dynamic-let restores dynamic variable after normal exit")
(check (equal? (dynamic-let ((*dynamic-let-variable* "middle"))
                (dynamic-let ((*dynamic-let-variable* "inner"))
                  *dynamic-let-variable*))
              "inner")
       "nested dynamic-let uses innermost value")
(check (equal? *dynamic-let-variable* "outer")
       "nested dynamic-let restores outer value")
(check (equal? (catch :dynamic-let-exit
                 (dynamic-let ((*dynamic-let-variable* "throwing"))
                   (throw :dynamic-let-exit *dynamic-let-variable*)))
              "throwing")
       "dynamic-let body can exit non-locally")
(check (equal? *dynamic-let-variable* "outer")
       "dynamic-let restores dynamic variable after non-local exit")

;;; OOP: number binary messages

(check (= [3 + 4] 7) "Number>>+ dispatches correctly")
(check (= [10 - 3] 7) "Number>>- dispatches correctly")
(check (= [3 * 4] 12) "Number>>* dispatches correctly")
(check (= [10 / 4] 5/2) "Number>>/ dispatches correctly")
(check [3 == 3] "Number>>== identity equal")
(check (let ((f 3.5)) [f == f]) "Number>>== float identity equal")
(check (not [3 == 4]) "Number>>== not equal")
(check [3 < 4] "Number>>< less than")
(check [4 > 3] "Number>>> greater than")
(check [3 <= 3] "Number>><= less than or equal")
(check [3 >= 3] "Number>>>= greater than or equal")
(check (= [-5/2 abs] 5/2) "Number>>abs preserves exact real magnitude")
(check-near [3+4i abs] 5.0 1e-12 "Number>>abs handles complex numbers")
(check-near [-2 phase] pi 1e-12 "Number>>phase handles negative reals")
(check-near [0+1i phase] (/ pi 2) 1e-12 "Number>>phase handles complex numbers")
(check (= [-5/2 floor] -3) "Number>>floor")
(check (= [-5/2 truncate] -2) "Number>>truncate")
(check (= [-5/2 ceiling] -2) "Number>>ceiling")
(check (= [-5/2 round] -3) "Number>>round")
(check-near [4 sqrt] 2.0 1e-12 "Number>>sqrt")
(check (= [4 min: 2] 2) "Number>>min:")
(check (= [4 max: 2] 4) "Number>>max:")
(check [0 zero?] "Number>>zero?")
(check [1 positive?] "Number>>positive?")
(check [-1 negative?] "Number>>negative?")
(check-near [(/ pi 2) sin] 1.0 1e-12 "Number>>sin")
(check-near [pi cos] -1.0 1e-12 "Number>>cos")
(check-near [0 tan] 0.0 1e-12 "Number>>tan")
(check-near [(expt 1) log] 1.0 1e-12 "Number>>log")
(check-near [2 expt] 7.38905609893065 1e-12 "Number>>expt")
(check (= [2 expt: 10] 1024) "Number>>expt: dispatches correctly")
(check (eq? (type-of [1+1i sin]) InexactComplexNumber) "Number>>sin accepts complex numbers")
(check (eq? (type-of [(- 1) log]) InexactComplexNumber)
       "Number>>log promotes negative real to complex")
(check (eq? (type-of [(- 1) expt: 1/2]) InexactComplexNumber)
       "Number>>expt: promotes negative base with non-integer exponent to complex")
(check (equal? [5/2 asString] "5/2") "Number>>asString formats rationals")
(check (equal? [(+ 340282366920938463463374607431768211456 1) asString]
               "340282366920938463463374607431768211457")
       "Number>>asString formats big integers")
(check (equal? [#true asString] "#true") "Object>>asString uses debug printing")
(check (equal? ["aλ" asString] "aλ") "String>>asString returns receiver")
(check (equal? [#\λ asString] "λ") "Character>>asString returns UTF-8 string")
(check (= [3 asFloat] 3.0) "RealNumber>>asFloat converts integers")
(check (= [1/2 asFloat] 0.5) "RealNumber>>asFloat converts rationals")

;;; Instants and durations

(let ((d [Duration fromSeconds: 3/2]))
  (check (= [d asMicroseconds] 1500000)
         "Duration class>>fromSeconds: preserves exact microseconds")
  (check (= [d asSeconds] 3/2)
         "Duration>>asSeconds preserves exact seconds"))
(check [[Duration fromSeconds: 1] = [Duration fromMicroseconds: 1000000]]
       "Duration equality uses microseconds")
(check [[Instant fromSeconds: 1] = [Instant fromMicroseconds: 1000000]]
       "Instant equality uses microseconds")
(let ((d [Duration fromMicroseconds: -500000]))
  (check (= [d asSeconds] -1/2)
         "Duration accepts negative microseconds"))
(let ((t [Instant fromSeconds: 10])
      (d [Duration fromSeconds: 2]))
  (check (= [[t afterDuration: d] asSeconds] 12)
         "Instant>>afterDuration: advances instant")
  (check (= [[t + d] asSeconds] 12)
         "Instant>>+ aliases afterDuration:")
  (check (= [[t beforeDuration: d] asSeconds] 8)
         "Instant>>beforeDuration: moves instant backward")
  (check (= [[t - d] asSeconds] 8)
         "Instant>>- subtracts duration")
  (check (= [[t durationSince: [Instant fromSeconds: 7]] asSeconds] 3)
         "Instant>>durationSince: returns duration")
  (check (= [[t durationUntil: [Instant fromSeconds: 13]] asSeconds] 3)
         "Instant>>durationUntil: returns duration")
  (check (= [[t - [Instant fromSeconds: 7]] asSeconds] 3)
         "Instant>>- subtracts instant as duration"))
(let ((d1 [Duration fromSeconds: 5])
      (d2 [Duration fromSeconds: 2])
      (t [Instant fromSeconds: 10]))
  (check (= [[d1 addDuration: d2] asSeconds] 7)
         "Duration>>addDuration: adds durations")
  (check (= [[d1 + d2] asSeconds] 7)
         "Duration>>+ aliases duration addition")
  (check (= [[d1 substractDuration: d2] asSeconds] 3)
         "Duration>>substractDuration: subtracts durations")
  (check (= [[d1 - d2] asSeconds] 3)
         "Duration>>- aliases duration subtraction")
  (check (= [[d2 + t] asSeconds] 12)
         "Duration>>+ advances instant"))
(check (eq? (type-of [Instant now]) Instant)
       "Instant class>>now returns an Instant")

;;; UTC date-times

(let ((dt [UTCDateTime fromYear: 1970
                       month: 1
                       day: 2
                       hour: 3
                       minute: 4
                       second: 5
                       microsecond: 123456]))
  (check (= [dt year] 1970) "UTCDateTime>>year")
  (check (= [dt month] 1) "UTCDateTime>>month")
  (check (= [dt day] 2) "UTCDateTime>>day")
  (check (= [dt hour] 3) "UTCDateTime>>hour")
  (check (= [dt minute] 4) "UTCDateTime>>minute")
  (check (= [dt second] 5) "UTCDateTime>>second")
  (check (= [dt microsecond] 123456) "UTCDateTime>>microsecond")
  (check (equal? [dt asISO8601] "1970-01-02T03:04:05.123456Z")
         "UTCDateTime>>asISO8601 emits UTC ISO8601")
  (check (equal? [dt asISO8601WithSeparator: #\space]
                 "1970-01-02 03:04:05.123456Z")
         "UTCDateTime>>asISO8601WithSeparator: accepts Character")
  (check (equal? [dt asISO8601WithSeparator: "_"]
                 "1970-01-02_03:04:05.123456Z")
         "UTCDateTime>>asISO8601WithSeparator: accepts String"))
(check (equal? [[UTCDateTime fromISO8601: "1970-01-02T03:04:05Z"] asISO8601]
               "1970-01-02T03:04:05Z")
       "UTCDateTime ISO8601 omits zero microseconds")
(let ((instant [Instant fromMicroseconds: 123456])
      (dt [UTCDateTime fromInstant: [Instant fromMicroseconds: 123456]]))
  (check (= [dt year] 1970) "UTCDateTime class>>fromInstant: year")
  (check (= [dt month] 1) "UTCDateTime class>>fromInstant: month")
  (check (= [dt day] 1) "UTCDateTime class>>fromInstant: day")
  (check (= [dt hour] 0) "UTCDateTime class>>fromInstant: hour")
  (check (= [dt minute] 0) "UTCDateTime class>>fromInstant: minute")
  (check (= [dt second] 0) "UTCDateTime class>>fromInstant: second")
  (check (= [dt microsecond] 123456) "UTCDateTime class>>fromInstant: microsecond")
  (check [[dt asInstant] = instant] "UTCDateTime>>asInstant round-trips"))
(let ((dt [UTCDateTime fromISO8601: "1970-01-02T03:04:05.123456Z"]))
  (check (= [dt year] 1970) "UTCDateTime class>>fromISO8601: year")
  (check (= [dt month] 1) "UTCDateTime class>>fromISO8601: month")
  (check (= [dt day] 2) "UTCDateTime class>>fromISO8601: day")
  (check (= [dt hour] 3) "UTCDateTime class>>fromISO8601: hour")
  (check (= [dt minute] 4) "UTCDateTime class>>fromISO8601: minute")
  (check (= [dt second] 5) "UTCDateTime class>>fromISO8601: second")
  (check (= [dt microsecond] 123456) "UTCDateTime class>>fromISO8601: microsecond")
  (check (equal? [dt asISO8601] "1970-01-02T03:04:05.123456Z")
         "UTCDateTime class>>fromISO8601: parses asISO8601 output"))
(let ((dt [UTCDateTime fromYear: 1970
                       month: 1
                       day: 1
                       hour: 0
                       minute: 0
                       second: 0
                       microsecond: 3/2]))
  (check (= [[dt asInstant] asMicroseconds] 3/2)
         "UTCDateTime>>asInstant preserves non-integer microseconds")
  (check (= [[UTCDateTime fromInstant: [dt asInstant]] microsecond] 3/2)
         "UTCDateTime class>>fromInstant: preserves non-integer microseconds"))
(check [[UTCDateTime fromYear: 2000
                     month: 2
                     day: 29
                     hour: 0
                     minute: 0
                     second: 0
                     microsecond: 0]
        = [UTCDateTime fromInstant:
             [[UTCDateTime fromYear: 2000
                           month: 2
                           day: 29
                           hour: 0
                           minute: 0
                           second: 0
                           microsecond: 0]
              asInstant]]]
       "UTCDateTime>>asInstant handles leap day directly")
(check-error-message "Day out of range"
                     "UTCDateTime>>asInstant rejects invalid civil day"
  [[UTCDateTime fromYear: 2023
                month: 2
                day: 29
                hour: 0
                minute: 0
                second: 0
                microsecond: 0]
   asInstant])

;;; OOP: identity and structural equal

(check (let ((p '(1 . 2))) [p == p]) "Object>>== identity equal same object")
(check (not ['(1) == '(1)]) "Object>>== not equal for distinct pairs")
(check [1 = 1] "Object>>equal: structurally equal fixnums")
(check ['(1 2) = '(1 2)] "Object>>equal: structurally equal lists")
(check (not ['(1 2) = '(1 3)]) "Object>>equal: structurally unequal lists")

;;; OOP: Pair methods

(check (= ['(1 . 2) car] 1) "Pair>>car dispatches correctly")
(check (= ['(1 . 2) cdr] 2) "Pair>>cdr dispatches correctly")
(let ((p (cons 5 6)))
  [p car: 42]
  (check (= [p car] 42) "Pair>>car: mutates car")
  (let ((q (cons 10 20)))
    [q cdr: 99]
    (check (= [q cdr] 99) "Pair>>cdr: mutates cdr")))

;;; OOP: String and Vector methods

(check (= ['(1 2 3) length] 3) "List>>length")
(check (= ['() length] 0) "Nil as empty List>>length")
(check (= ['(1 2 3) at: 1] 2) "List>>at: dispatches correctly")
(check (= ["hello" length] 5) "String>>length")
(check (eq? ["hello" at: 1] (string-ref "hello" 1)) "String>>at: dispatches correctly")
(check (equal? ["aλ" append: "😀z"] "aλ😀z") "String>>append: concatenates")
(check (equal? ["aλ😀z" from: 1 to: 3] "λ😀")
       "String>>from:to: uses half-open codepoint indexes")
(check (equal? ["aλ😀z" substringFrom: 1 to: 3] "λ😀")
       "String>>substringFrom:to: uses half-open codepoint indexes")
(check (equal? ["bananana" replace: "na" with: "λ"] "baλλλ")
       "String>>replace:with: replaces all occurrences")
(check (equal? ["bananana" replaceFirst: "na" with: "λ"] "baλnana")
       "String>>replaceFirst:with: replaces first occurrence")
(check (equal? ["aλ😀" replace: "λ" with: "LL"] "aLL😀")
       "String>>replace:with: handles Unicode codepoint boundaries")
(check ["bananana" contains?: "nan"] "String>>contains?: finds substring")
(check (not ["bananana" contains?: "xyz"])
       "String>>contains?: rejects absent substring")
(check ["aλ😀" startsWith?: "aλ"] "String>>startsWith?: accepts prefix")
(check ["aλ😀" startsWith?: ""] "String>>startsWith?: accepts empty prefix")
(check (not ["aλ😀" startsWith?: "λ"])
       "String>>startsWith?: rejects non-prefix")
(check (not ["aλ😀" startsWith?: "aλ😀z"])
       "String>>startsWith?: rejects longer prefix")
(check (= ["aλ😀λ" find: "😀"] 2)
       "String>>find: returns codepoint index")
(check (null? ["aλ😀λ" find: "z"])
       "String>>find: returns nil for absent substring")
(check (equal? ["bananana" findAll: "na"] '(2 4 6))
       "String>>findAll: returns match codepoint indices")
(check (equal? ["aλ😀λ" findAll: "λ"] '(1 3))
       "String>>findAll: counts Unicode codepoints")
(let ((mapping [IdentityDictionary new]))
  [mapping at: (string-ref "abc" 0) put: (string-ref "XYZ" 0)]
  [mapping at: (string-ref "abc" 1) put: "yy"]
  (check (equal? ["abcλ" mapCharacters: mapping] "Xyycλ")
         "String>>mapCharacters: maps Character keys to Character or String values"))
(check (equal? ["  a\tλ\n 😀  " substrings] '("a" "λ" "😀"))
       "String>>substrings splits on whitespace without empty substrings")
(check (let ((seen '()))
         (and (null? ["  a λ  " substringsDo:
                     (lambda (each) (set! seen (cons each seen)))])
              (equal? seen '("λ" "a"))))
       "String>>substringsDo: calls callable without constructing a list")
(check (equal? ["a--λ----😀--" substrings: "--"] '("a" "λ" "" "😀" ""))
       "String>>substrings: splits on delimiter string with empty substrings")
(check (let ((seen '()))
         (and (null? ["a--λ----😀--" substrings: "--" do:
                     (lambda (each) (set! seen (cons each seen)))])
              (equal? seen '("" "😀" "" "λ" "a"))))
       "String>>substrings:do: calls callable for empty substrings")
(check (equal? ["a,λ,,😀," splitOn: #\,] '("a" "λ" "" "😀" ""))
       "String>>splitOn: splits on Character")
(check (equal? ["a,λ;😀" splitOn: ",;"] '("a" "λ" "😀"))
       "String>>splitOn: splits on any character in String")
(check (equal? ["a,λ;😀" splitOn: [Set fromList: (list #\, #\;)]]
               '("a" "λ" "😀"))
       "String>>splitOn: splits on any character in Set")
(check (let ((seen '()))
         (and (null? ["a,λ,,😀," splitOn: #\, do:
                     (lambda (each) (set! seen (cons each seen)))])
              (equal? seen '("" "😀" "" "λ" "a"))))
       "String>>splitOn:do: calls callable for empty substrings")
(check (equal? (string-join ", " '("a" "λ" "😀")) "a, λ, 😀")
       "string-join joins list with delimiter")
(check (equal? ["-" join: '("a" "λ" "😀")] "a-λ-😀")
       "String>>join: uses receiver as delimiter")
(check (equal? [", " join: '()] "")
       "String>>join: returns empty string for empty list")
(check (equal? (format "a=~a s=~s~~~%" 42 "x") "a=42 s=\"x\"~\n")
       "format supports ~a, ~s, ~~, and ~%")
(check (equal? (format "~{[~a]~}" '(1 2 3)) "[1][2][3]")
       "format supports ~{...~} iteration")
(check (equal? (format "~{~a=~s; ~}" '("x" 1 "y" 2)) "x=1; y=2; ")
       "format iteration body can consume multiple arguments")
(check (equal? (format "~:{~a=~s; ~}" '(("x" 1) ("y" 2))) "x=1; y=2; ")
       "format supports colon iteration over argument lists")
(check (equal? (format "~2{[~a]~} ~@{~a~}" '(1 2 3) "ab") "[1][2] ab")
       "format supports numeric iteration limits and at-sign asList iteration")
(check (equal? (format "~:@{~a=~s; ~}" #(#("x" 1) #("y" 2))) "x=1; y=2; ")
       "format supports colon-at-sign iteration over asList sublists")
(check (equal? (format "~d ~d ~b ~o ~x" 42 5/2 -10 #o777 #xBEEF)
               "42 2.5 -1010 777 beef")
       "format supports decimal, binary, octal, and hexadecimal numeric directives")
(check (equal? (format "~f ~e ~g" 5/2 2500 5/2) "2.500000 2.500000e+03 2.5")
       "format supports fixed, exponential, and general float directives")
(check (equal? (format "~x" #x10000000000000000) "10000000000000000")
       "format radix directives support big integers")
(check (equal? (format "~a ~s ~a ~s" "x" "x" #\λ #\λ)
               "x \"x\" λ #\\u+03bb")
       "format distinguishes display and debug strings and characters")
(define-class FormatAsStringThing (Object) ())
(define-method [FormatAsStringThing asString] "custom-format-value")
(let ((value [FormatAsStringThing alloc]))
  (check (equal? (format "~a" value) "custom-format-value")
         "format ~a dispatches asString")
  (check (not (equal? (format "~s" value) "custom-format-value"))
         "format ~s uses debug printing without asString dispatch"))
(check (eq? [#(1 2 3) at: 1] 2) "Vector>>at: dispatches correctly")
(check (equal? ['(1 2 3) asList] '(1 2 3)) "List>>asList returns receiver")
(check (equal? [#(1 2 3) asList] '(1 2 3)) "Vector>>asList converts elements")
(let ((v #(1 2 3)))
  [v at: 1 put: 9]
  (check (eq? [v at: 1] 9) "Vector>>at:put: mutates element"))
(check (= [(bytevector 65 200 66) length] 3) "ByteVector>>length")
(check (= [(bytevector 65 200 66) at: 1] 200)
       "ByteVector>>at: returns unsigned bytes")
(let ((bv (bytevector 1 2 3)))
  [bv at: 1 put: 255]
  (check (= [bv at: 1] 255) "ByteVector>>at:put: mutates bytes"))
(check (equal? [(bytevector 65 66) append: (bytevector 67)] (bytevector 65 66 67))
       "ByteVector>>append: concatenates")
(check (equal? [(bytevector 10 20 30 40) from: 1 to: 3] (bytevector 20 30))
       "ByteVector>>from:to: uses half-open byte indexes")
(check (equal? [(bytevector 65 200 66) asList] '(65 200 66))
       "ByteVector>>asList converts bytes")
(check (equal? ["aλ" asByteVector] (string->bytevector "aλ"))
       "String>>asByteVector converts to ByteVector")
(check (equal? [(string->bytevector "aλ") asString] "aλ")
       "ByteVector>>asString converts to String")
(check (equal? ["aλ" asList] '(#\a #\λ)) "String>>asList converts characters")

;;; make-class and make-instance

(let ((MakePoint (make-class 'Point (list Object) '(x y))))
  (check (class? MakePoint) "make-class returns class object")
  (let ((inst (make-instance MakePoint)))
    (check (eq? (type-of inst) MakePoint) "make-instance returns instance of class"))
  (let ((inst [MakePoint alloc]))
    (check (eq? (type-of inst) MakePoint) "Class>>alloc creates instance")))

(check-error-message "Class is not allocatable"
                     "make-instance non-allocatable class signals error"
  (make-instance Symbol))

(check-error-message "Class is not allocatable"
                     "Class>>alloc non-allocatable class signals error"
  [Symbol alloc])

;;; Class>>addMethod:withSelector:

(let ((MakePoint2 (make-class 'Point2 (list Object) '(x y))))
  [MakePoint2 addMethod: (lambda (self) (slot-ref self 'x))
              withSelector: :get-x]
  (let ((inst (make-instance MakePoint2)))
    (slot-set! inst 'x 77)
    (check (= [inst get-x] 77) "Class>>addMethod:withSelector: installs method")))

;;; Pairs / list primitives

(check (equal? (cons 1 2) '(1 . 2)) "cons creates pair")
(check (= (car '(1 . 2)) 1) "car returns first element")
(check (= (cdr '(1 . 2)) 2) "cdr returns second element")
(check (pair? '(1 . 2)) "pair? true for pair")
(check (not (pair? 1)) "pair? false for non-pair")
(check (equal? (list 1 2 3) '(1 2 3)) "list constructor")
(check (list? '(1 2 3)) "list? true for proper list")
(check (not (list? '(1 . 2))) "list? false for dotted pair")
(check (equal? ['(1 2 3) map: (lambda (x) (+ x 2))] '(3 4 5))
       "List>>map: maps callable across receiver")
(check (let ((seen '()))
         (and (null? ['(1 2 3) forEach: (lambda (x) (set! seen (cons x seen)))])
              (equal? seen '(3 2 1))))
       "List>>forEach: applies callable across receiver")
(check ['(1 2 3) any: (lambda (x) (= x 2))]
       "List>>any: returns true when any element matches")
(check (not ['(1 2 3) any: (lambda (x) (= x 9))])
       "List>>any: returns false when no element matches")
(check ['(1 2 3) every: (lambda (x) (< x 4))]
       "List>>every: returns true when every element matches")
(check (not ['(1 2 3) every: (lambda (x) (< x 3))])
       "List>>every: returns false when an element misses")
(check (= ['(1 2 3) reduce: +] 6) "List>>reduce: reduces receiver from the left")
(check (= ['(1 2 3) inject: 10 into: +] 16)
       "List>>inject:into: folds receiver from the left")

;;; Set

(check (eq? (type-of [Set new]) Set) "Set>>new returns set")
(let ((s [Set new]))
  [s put: 1]
  [s put: 2]
  [s put: 1]
  (check [s contains?: 1] "Set>>contains?: finds inserted item")
  (check (not [s contains?: 3]) "Set>>contains?: rejects absent item")
  (check (= [[s asList] reduce: +] 3) "Set>>asList returns unique elements"))
(let ((s [Set fromList: '(1 2 1 3)]))
  (check (and [s contains?: 1] [s contains?: 2] [s contains?: 3])
         "Set class>>fromList: inserts list elements")
  (check (= [[s asList] reduce: +] 6) "Set class>>fromList: removes duplicates")
  (check (let ((seen '()))
           (and (null? [s forEach: (lambda (x) (set! seen (cons x seen)))])
                (= [seen reduce: +] 6)))
         "Set>>forEach: applies callable across receiver")
  (check [s any: (lambda (x) (= x 2))]
         "Set>>any: returns true when any element matches")
  (check (not [s any: (lambda (x) (= x 9))])
         "Set>>any: returns false when no element matches")
  (check [s every: (lambda (x) (< x 4))]
         "Set>>every: returns true when every element matches")
  (check (not [s every: (lambda (x) (< x 3))])
         "Set>>every: returns false when an element misses")
  (check (= [s inject: 10 into: +] 16)
         "Set>>inject:into: folds receiver with initial value")
  (check (= [s reduce: +] 6) "Set>>reduce: reduces receiver"))
(check-raises "Set>>reduce: rejects empty set" [[Set new] reduce: +])

;;; IdentitySet

(let ((a (list 1))
      (b (list 1))
      (c (list 1)))
  (let ((s [IdentitySet new]))
    [s put: a]
    [s put: b]
    [s put: a]
    (check (eq? (type-of s) IdentitySet) "IdentitySet>>new returns identity set")
    (check [s contains?: a] "IdentitySet>>contains?: finds identical item")
    (check [s contains?: b] "IdentitySet>>contains?: preserves distinct equal item")
    (check (not [s contains?: c]) "IdentitySet>>contains?: rejects equal non-identical item")
    (check (= [[s asList] inject: 0 into: (lambda (count each) (+ count 1))] 2)
           "IdentitySet>>put: collapses by identity only")))
(let ((a (list 1)))
  (let ((s [IdentitySet fromList: (list a (list 1) a)]))
    (check (= [[s asList] inject: 0 into: (lambda (count each) (+ count 1))] 2)
           "IdentitySet class>>fromList: removes duplicate identities")
    (check (let ((seen '()))
             (and (null? [s forEach: (lambda (x) (set! seen (cons x seen)))])
                  (= [seen inject: 0 into: (lambda (count each) (+ count 1))] 2)))
           "IdentitySet>>forEach: uses inherited Set method")
    (check [s any: (lambda (x) (eq? x a))]
           "IdentitySet>>any: uses inherited Set method")
    (check [s every: list?]
           "IdentitySet>>every: uses inherited Set method")
    (check (= [s inject: 0 into: (lambda (count each) (+ count 1))] 2)
           "IdentitySet>>inject:into: uses inherited Set method")
    (check (= [s reduce: (lambda (left right) 9)] 9)
           "IdentitySet>>reduce: uses inherited Set method")))
(check-raises "IdentitySet>>reduce: rejects empty set" [[IdentitySet new] reduce: +])

;;; Equality primitives

(check (= 1 1) "= equal fixnums")
(check (not (= 1 2)) "= unequal fixnums")
(check (= 1/2 2/4) "= equal fractions")
(check (= 340282366920938463463374607431768211456
          340282366920938463463374607431768211456)
       "= equal big integers")
(check (= 1+2i 1+2i) "= equal complex numbers")
(check-raises "= type error on non-number" (= 1 "x"))
(check (eq? 'a 'a) "eq? identical symbols")
(check (not (eq? '(1) '(1))) "eq? distinct pairs")
(check (eqv? 1 1) "eqv? equal fixnums")
(check (eqv? 1.0 1.0) "eqv? equal floats")
(check (equal? '(1 2 3) '(1 2 3)) "equal? structurally equal lists")
(check (not (equal? '(1 2) '(1 3))) "equal? structurally unequal lists")

;;; Ordering

(check (< 1 2) "< true")
(check (not (< 2 1)) "< false")
(check (<= 1 1) "<= equal")
(check (> 2 1) "> true")
(check (>= 2 2) ">= equal")
(check (not (not #true)) "not of true is false")
(check (not #false) "not of false is true")

;;; List operations

(check (equal? (append '(1 2) '(3 4)) '(1 2 3 4)) "append")
(check (= (length '(1 2 3)) 3) "length returns proper list length")
(check (= (length '()) 0) "length returns zero for empty list")
(check-raises "length raises on improper list"
  (length '(1 . 2)))
(check (equal? (reverse '(1 2 3)) '(3 2 1)) "reverse returns reversed list")
(check (equal? (reverse '()) '()) "reverse returns empty list for empty list")
(check-raises "reverse raises on improper list"
  (reverse '(1 . 2)))
(check (equal? (map (lambda (x) (+ x 1)) '(1 2 3)) '(2 3 4))
       "map applies callable across single list")
(check (equal? (map + '(1 2 3) '(10 20 30 40)) '(11 22 33))
       "map terminates on shortest list when mapping multiple lists")
(check (let ((seen '()))
         (and (null? (for-each (lambda (x y) (set! seen (cons (+ x y) seen)))
                               '(1 2 3)
                               '(10 20)))
              (equal? seen '(22 11))))
       "for-each applies callable and terminates on shortest list")
(check (any (lambda (x) (= x 2)) '(1 2 3)) "any returns true for a matching element")
(check (not (any (lambda (x) (= x 9)) '(1 2 3))) "any returns false without a match")
(check (let ((count 0))
         (and (any (lambda (x) (set! count (+ count 1)) (= x 3)) '(1 2 3 4))
              (= count 3)))
       "any short-circuits after truthy result")
(check (every (lambda (x) (< x 4)) '(1 2 3)) "every returns true when all match")
(check (not (every (lambda (x) (< x 3)) '(1 2 3))) "every returns false on first miss")
(check (let ((count 0))
         (and (not (every (lambda (x) (set! count (+ count 1)) (< x 3)) '(1 2 3 4)))
              (= count 3)))
       "every short-circuits after falsey result")
(check (not (any (lambda (x) x) '())) "any returns false for an empty list")
(check (every (lambda (x) x) '()) "every returns true for an empty list")
(check (= (fold-left (lambda (acc x) (- acc x)) 0 '(1 2 3)) -6)
       "fold-left folds from the left")
(check (= (fold-right (lambda (x acc) (- x acc)) 0 '(1 2 3)) 2)
       "fold-right folds from the right")
(check (= (fold-left (lambda (acc x y) (+ acc x y)) 0 '(1 2 3) '(10 20)) 33)
       "fold-left terminates on shortest list when folding multiple lists")
(check (equal? (fold-right (lambda (x y acc) (cons (+ x y) acc))
                           '()
                           '(1 2 3)
                           '(10 20))
               '(11 22))
       "fold-right terminates on shortest list when folding multiple lists")
(check (= (fold-left + 5 '()) 5) "fold-left returns initial value for empty list")
(check (= (fold-right + 5 '()) 5) "fold-right returns initial value for empty list")
(check (= (reduce-left (lambda (acc x) (- acc x)) '(10 1 2)) 7)
       "reduce-left reduces from the left")
(check (= (reduce-right (lambda (x acc) (- x acc)) '(10 1 2)) 11)
       "reduce-right reduces from the right")
(check (equal? (reduce-left (lambda args args) '(1 2) '(10 20)) '((1 10) 2 20))
       "reduce-left uses first element tuple as seed with multiple lists")
(check (equal? (reduce-right (lambda args args) '(1 2) '(10 20)) '(1 10 (2 20)))
       "reduce-right uses rightmost element tuple as seed with multiple lists")
(check-raises "reduce-left raises on empty list"
  (reduce-left + '()))
(check-raises "reduce-right raises on empty list"
  (reduce-right + '()))
(check (equal? (memq 'b '(a b c)) '(b c)) "memq returns matching tail")
(check (not (memq (string-append "a" "") '("a"))) "memq returns false on identity miss")
(check (equal? (assoc "ab" '(("ab" . 3) ("cd" . 4))) '("ab" . 3)) "assoc matches structurally")
(check (equal? (assq 'b '((a . 1) (b . 2))) '(b . 2)) "assq matches by identity")
(check (not (assq (string-append "a" "") '(("a" . 1)))) "assq returns false on identity miss")
(check (equal? (assv 1.0 '((1 . 9))) '(1 . 9)) "assv matches numerically equivalent keys")
(check (equal? (alist->plist '((a . 1) (b . 2))) '(a 1 b 2))
       "alist->plist converts associations to property list")
(check (equal? (plist->alist '(a 1 b 2)) '((a . 1) (b . 2)))
       "plist->alist converts property list to associations")
(check-raises "plist->alist raises on odd length property list"
  (plist->alist '(a 1 b)))
(check (= (list-ref '(4 5 6) 1) 5) "list-ref returns item at index")
(check-error-message "List index out of bounds"
                     "list-ref signals out of bounds"
  (list-ref '(4 5 6) 3))
(check (equal? (vector->list (list->vector '(4 5 6))) '(4 5 6))
       "list->vector and vector->list round-trip")
(check (= (vector-length (list->vector '())) 0)
       "list->vector accepts empty list")
(check-raises "list->vector raises on improper list"
  (list->vector '(1 . 2)))
(check (= (caar '((1 . 2) . 3)) 1) "caar")
(check (= (cadr '(1 2 3)) 2) "cadr")
(check (= (caddr '(1 2 3 4)) 3) "caddr")
(check (= (cadddr '(1 2 3 4 5)) 4) "cadddr")

;;; Strings

(check (string? "abc") "string? true for string")
(check (not (string? 1)) "string? false for non-string")
(check (= (string-length "hello") 5) "string-length")
(check (= (string-length "aλ😀") 3) "string-length counts unicode codepoints")
(check (equal? (string-ref "ABC" 1) (string-ref "xBx" 1)) "string-ref returns character")
(check (equal? (string-ref "aλ😀" 1) #\λ) "string-ref returns BMP unicode character")
(check (equal? (string-ref "aλ😀" 2) #\U+1f600) "string-ref returns astral unicode character")
(check (equal? "\u03BB\U01F600" "λ😀")
       "string reader supports unicode escapes")
(check (equal? "\xFF" "ÿ")
       "string reader hex escape is a unicode codepoint")
(check (character? (string-ref "x" 0)) "character? true for character")
(check (not (character? 1)) "character? false for non-character")
(check (equal? (string->list "ABC") (list (string-ref "ABC" 0)
                                          (string-ref "ABC" 1)
                                          (string-ref "ABC" 2)))
       "string->list round-trip")
(check (equal? (string->list "aλ😀") (list #\a #\λ #\U+1f600))
       "string->list uses unicode codepoints")
(check (equal? (list->string (string->list "hello")) "hello") "list->string round-trip")
(check (equal? (list->string (list #\a #\λ #\U+1f600)) "aλ😀")
       "list->string encodes unicode codepoints")
(check (equal? (string-append "ab" "cd") "abcd") "string-append concatenates")
(check (equal? (string-append "aλ" "😀") "aλ😀")
       "string-append preserves unicode codepoints")
(check (equal? (substring "aλ😀z" 1 3) "λ😀")
       "substring uses half-open unicode codepoint indexes")
(check (equal? (substring "aλ😀z" 0 4) "aλ😀z") "substring can span whole string")
(check (equal? (substring "aλ😀z" 2 2) "") "substring supports empty ranges")

;;; Vectors

(check (vector? #(1 2)) "vector? true for vector")
(check (not (vector? 1)) "vector? false for non-vector")
(check (= (vector-length #(1 2 3)) 3) "vector-length")
(check (= (vector-ref (vector 4 5 6) 2) 6) "vector constructor and vector-ref")
(check (= (vector-ref (make-vector 3 9) 1) 9) "make-vector with fill value")
(check (equal? (vector->list #(1 2 3)) '(1 2 3)) "vector->list converts elements")
(check (equal? (vector->list (make-vector 0)) '()) "vector->list accepts empty vector")
(let ((v (vector 1 2 3)))
  (vector-set! v 1 99)
  (check (= (vector-ref v 1) 99) "vector-set! mutates vector"))

;;; ByteVectors

(check (bytevector? (bytevector 1 2)) "bytevector? true for bytevector")
(check (not (bytevector? 1)) "bytevector? false for non-bytevector")
(check (equal? #u8(1 2 255) (bytevector 1 2 255))
       "#u8 reader syntax creates bytevectors")
(check (equal? #"A\nZ" (bytevector 65 10 90))
       "#\"\" reader syntax creates ASCII bytevectors")
(check (equal? #"\a\b\f\n\r\t\v\\\'\"\?\101\xFF\u0042\U000043"
               (bytevector 7 8 12 10 13 9 11 92 39 34 63 65 255 66 67))
       "#\"\" reader syntax supports common C escapes")
(check (= (bytevector-length (bytevector 1 2 3)) 3) "bytevector-length")
(check (= (bytevector-u8-ref (bytevector 4 255 6) 1) 255)
       "bytevector-u8-ref returns unsigned fixnum")
(let ((bv (make-bytevector 3 9)))
  (bytevector-u8-set! bv 1 200)
  (check (= (bytevector-u8-ref bv 1) 200)
         "bytevector-u8-set! mutates bytevector"))
(check (equal? (bytevector-append (bytevector 1 2) (bytevector 3 4))
               (bytevector 1 2 3 4))
       "bytevector-append concatenates")
(check (equal? (bytevector-copy (bytevector 1 2 3 4) 1 3)
               (bytevector 2 3))
       "bytevector-copy slices half-open byte indexes")
(check (equal? (bytevector->string (string->bytevector "aλ😀")) "aλ😀")
       "string bytevector conversion round-trip")
(check (= (bytevector-length (string->bytevector "λ")) 2)
       "string->bytevector exposes UTF-8 bytes")

;;; OS module

(define (contains-string? items target)
  (any (lambda (item) (equal? item target)) items))

(check (string? (ListTalk-OS:getenv "PATH")) "getenv returns string for present variable")
(check (null? (ListTalk-OS:getenv "__LISTTALK_EVAL_TEST_MISSING_ENV__"))
       "getenv returns nil for missing variable")
(check (string? (ListTalk-OS:getpwd)) "getpwd returns current directory")
(let ((bytes (ListTalk-OS:getentropy 300)))
  (check (eq? (type-of bytes) ByteVector) "getentropy returns ByteVector")
  (check (= (bytevector-length bytes) 300) "getentropy returns requested length"))

(let* ((seed (ListTalk-OS:getentropy 4))
       (original-cwd (ListTalk-OS:getpwd))
       (suffix (string-append
                 (number->string (bytevector-u8-ref seed 0)) "-"
                 (number->string (bytevector-u8-ref seed 1)) "-"
                 (number->string (bytevector-u8-ref seed 2)) "-"
                 (number->string (bytevector-u8-ref seed 3))))
       (root (string-append original-cwd "/listtalk-os-" suffix))
       (nested (string-append root "/nested/child/grandchild"))
       (original (string-append root "/alpha.txt"))
       (moved (string-append root "/beta.txt"))
       (hard (string-append root "/hard.txt"))
       (soft (string-append root "/soft.txt")))
  (ListTalk-OS:mkdir root)
  (check (ListTalk-OS:access root) "mkdir creates directory")
  (ListTalk-OS:mkdirs nested)
  (check (ListTalk-OS:access nested) "mkdirs creates parent directories")
  (ListTalk-OS:mkdirs nested)
  (check (ListTalk-OS:access nested) "mkdirs accepts existing directory")
  (check (equal? (ListTalk-OS:chdir root) root) "chdir returns new directory")
  (check (equal? (ListTalk-OS:getpwd) root) "getpwd reflects chdir")
  (ListTalk-OS:chdir original-cwd)
  (let ((stream [FileStream newForOutput: original]))
    [stream writeString: "alpha"]
    [stream close])
  (check (ListTalk-OS:access original) "access sees created file")
  (ListTalk-OS:move original moved)
  (check (ListTalk-OS:access moved) "move renames file")
  (check (not (ListTalk-OS:access original)) "move removes old path")
  (ListTalk-OS:link moved hard)
  (check (ListTalk-OS:access hard) "link creates hard link")
  (ListTalk-OS:symlink moved soft)
  (check (ListTalk-OS:access soft) "symlink creates directory entry")
  (check (equal? (ListTalk-OS:readlink soft) moved) "readlink returns symlink target")
  (let ((entries (ListTalk-OS:list-directory root)))
    (check (contains-string? entries "beta.txt") "list-directory contains moved file")
    (check (contains-string? entries "hard.txt") "list-directory contains hard link")
    (check (contains-string? entries "soft.txt") "list-directory contains symlink"))
  (ListTalk-OS:unlink hard)
  (ListTalk-OS:unlink soft)
  (ListTalk-OS:unlink moved))

;;; Slot access

(let ((p (cons 1 2)))
  (check (= (slot-ref p 'car) 1) "slot-ref reads pair slot"))
(let ((p (cons 1 2)))
  (slot-set! p 'car 77)
  (check (= (slot-ref p 'car) 77) "slot-set! mutates pair slot"))
(check (eq? (slot-ref (type-of 1) 'name) 'SmallInteger)
       "slot-ref resolves through superclass slots")
(let ((metaclass-name (slot-ref (type-of SmallInteger) 'name)))
  (check (symbol? metaclass-name) "metaclass name slot contains symbol")
  (check (equal? [metaclass-name name] "SmallInteger class")
         "metaclass gets synthesized class name"))

;;; Quote and quasiquote

(check (equal? (quote (+ 1 2)) '(+ 1 2)) "quote does not evaluate")
(check (equal? '(+ 1 2) (quote (+ 1 2))) "quote reader syntax")
(check (equal? `(+ ,(+ 1 2) 4) '(+ 3 4)) "quasiquote with unquote")
(check (equal? `(1 ,@(list 2 3) 4) '(1 2 3 4)) "quasiquote with unquote-splicing")

;;; Lambda

(check (= ((lambda (x y) (+ x y)) 3 4) 7) "closure application")
(check (equal? ((lambda (x . rest) rest) 1 2 3) '(2 3)) "dotted rest parameter")
(check (equal? ((lambda args args) 4 5) '(4 5)) "symbol rest parameter")

;;; Tail call optimization

(define (make-deep-list-loop i acc n)
  (if (= i n)
      acc
      (make-deep-list-loop (+ i 1) (cons '() acc) n)))

(define (make-deep-list n)
  (make-deep-list-loop 0 '() n))

(define (len-loop xs acc)
  (if xs (len-loop (cdr xs) (+ acc 1)) acc))

(check (= (len-loop (make-deep-list 20000) 0) 20000)
       "tail recursion stays bounded and returns expected value")

;;; if

(check (= (if '() 1 2) 2) "if nil branch is false")
(check (= (if #false 1 2) 2) "if #false branch is false")
(check (= (if #true 1 2) 1) "if #true branch is true")

;;; and

(check (eq? (and) #true) "and with no expressions returns true")
(check (= (and 1 2 3) 3) "and returns last truthy value")
(check (eq? (and 1 '() (error "skipped")) '()) "and returns first falsey value")
(let ((x 0))
  (and #false (set! x 1))
  (check (= x 0) "and short-circuits after falsey value"))
(and #true (define and-defined 23))
(check (= and-defined 23) "and does not wrap later forms in a lexical environment")

;;; or

(check (eq? (or) #false) "or with no expressions returns false")
(check (= (or '() #false 7 (error "skipped")) 7) "or returns first truthy value")
(check (eq? (or '() #false) #false) "or returns last falsey value")
(let ((x 0))
  (or 5 (set! x 1))
  (check (= x 0) "or short-circuits after truthy value"))
(define or-anchor #false)
(or or-anchor (define or-defined 24))
(check (= or-defined 24) "or does not wrap later forms in a lexical environment")

;;; cond

(check (= (cond ('() (error "skipped")) ((= 1 1) 42) (else 99)) 42)
       "cond evaluates first truthy clause body")
(check (= (cond ('() 1) (else 2 3)) 3) "cond else clause evaluates body sequence")
(check (= (cond ((+ 1 2))) 3) "cond clause without body returns test value")
(check (eq? (cond ('() 1)) #false) "cond without matching clause returns false")
(cond (#true (define cond-defined 25)))
(check (= cond-defined 25) "cond does not wrap clause bodies in a lexical environment")

;;; begin

(check (eq? (begin) '()) "begin with no forms returns nil")
(check (= (begin 1 2 3) 3) "begin returns last body value")
(begin (define begin-defined 26))
(check (= begin-defined 26) "begin evaluates body in current environment")

;;; let

(check (= (let ((x 1) (y 2)) (+ x y)) 3) "let binds local names")
(define outer-x 10)
(check (= (let ((x 1) (y outer-x)) y) 10)
       "let evaluates binding expressions in outer environment")
(check (= (let ((x 99)) x) 99) "let local binding shadows outer")
(check (= outer-x 10) "let local binding does not leak to outer environment")
(check (= (let loop ((n 5) (acc 1))
            (if (= n 0)
                acc
                (loop (- n 1) (* acc n))))
          120)
       "let supports named let")

;;; let*

(check (= (let* ((x 1)
                 (y (+ x 2))
                 (z (+ y 3)))
            (+ x y z))
          10)
       "let* evaluates bindings sequentially")

;;; letrec

(check (= (letrec ((even? (lambda (n)
                            (if (= n 0)
                                #true
                                (odd? (- n 1)))))
                   (odd? (lambda (n)
                           (if (= n 0)
                               #false
                               (even? (- n 1))))))
            (if (and (even? 10) (odd? 9))
                1
                0))
          1)
       "letrec supports mutually recursive bindings")

;;; define

(define add1 (lambda (x) (+ x 1)))
(check (= (add1 9) 10) "define binds value in current environment")

(define (add2 x y) (+ x y))
(check (= (add2 3 4) 7) "define function shorthand creates callable binding")

(define (bump x) (set! x (+ x 1)) x)
(check (= (bump 9) 10) "define function shorthand keeps full function body sequence")

(check (closure? add2) "lambda returns closure")

;;; define function/macro constant bindings

(define (const-fn x) x)
(let ((c (raises? (lambda () (set! const-fn (lambda (x) x))))))
  (check (and c (equal? (slot-ref c 'message)
                        "Special form set! expected existing mutable binding"))
         "define function shorthand creates constant binding"))

(define-macro (inc-macro x) (list '+ x 1))
(check (= (inc-macro 41) 42) "define-macro shorthand defines macro")

(let ((c (raises? (lambda () (set! inc-macro (macro (lambda (x) x)))))))
  (check (and c (equal? (slot-ref c 'message)
                        "Special form set! expected existing mutable binding"))
         "define-macro creates constant binding"))

;;; Gensym (behavioral)

(check (symbol? (gensym)) "gensym returns symbol")
(check (null? (slot-ref (gensym) 'package)) "gensym returns uninterned symbol")
(check (not (eq? (gensym) (gensym))) "gensym returns unique symbols")
(check (null? (slot-ref (gensym "tmp") 'package))
       "gensym with string name behaves like uninterned symbol")
(check (null? (slot-ref (gensym 'symtmp) 'package))
       "gensym with symbol name behaves like uninterned symbol")
(check (null? (slot-ref [Symbol gensym] 'package))
       "Symbol class>>gensym returns uninterned symbol")
(let ((u [Symbol uninterned: 'temp]))
  (check (null? (slot-ref u 'package)) "Symbol class>>uninterned: returns uninterned symbol")
  (check (equal? ['temp name] "temp") "Symbol>>name returns symbol name string"))
(let* ((package [Package named: "EvalSymbolClassPackage"])
       (same-package [Package named: 'EvalSymbolClassPackage])
       (symbol [Symbol intern: "value" in: package])
       (same-symbol [Symbol intern: 'value in: "EvalSymbolClassPackage"])
       (keyword [Symbol keyword: "class-keyword"]))
  (check (eq? package same-package) "Package class>>named: returns existing package")
  (check (eq? [symbol package] package) "Symbol class>>intern:in: uses package object")
  (check (eq? symbol same-symbol) "Symbol class>>intern:in: interns by name and package")
  (check (keyword? keyword) "Symbol class>>keyword: returns keyword symbol")
  (check [keyword keyword?] "Symbol class>>keyword: result answers keyword?"))

;;; with-gensyms

(let ((result (with-gensyms (a b)
                (list (symbol? a)
                      (symbol? b)
                      (eq? a b)
                      (null? (slot-ref a 'package))
                      (null? (slot-ref b 'package))))))
  (check (car result) "with-gensyms binds symbol for first name")
  (check (cadr result) "with-gensyms binds symbol for second name")
  (check (not (caddr result)) "with-gensyms symbols are distinct")
  (check (cadddr result) "with-gensyms first symbol is uninterned")
  (check (car (cddddr result)) "with-gensyms second symbol is uninterned"))

;;; set!

(define set-x 10)
(set! set-x 42)
(check (= set-x 42) "set! updates existing binding")

(define set-y 1)
((lambda () (set! set-y 9)))
(check (= set-y 9) "set! updates lexical parent binding")

;;; when and unless

(check (= (when #true 7) 7) "when with true condition evaluates body")
(check (eq? (when #false 7) '()) "when with false condition returns nil")
(check (= (unless #false 7) 7) "unless with false condition evaluates body")
(check (eq? (unless #true 7) '()) "unless with true condition returns nil")

;;; define-class and define-method

(define-class DefPoint (Object) (x y))
(let ((inst (make-instance DefPoint)))
  (check (eq? (type-of inst) DefPoint) "define-class wraps make-class and define"))

(define-method [Pair first] (%self-slot car))
(check (= [(cons 9 8) first] 9) "define-method installs zero-argument method")
(check (closure? [Pair lookupSelector: :first])
       "define-method installs closure as method")

(define-method [Pair setFirst: value]
  (set! (%self-slot car) value)
  (%self-slot car))
(check (= [(cons 9 8) setFirst: 42] 42)
       "define-method method body can use %self-slot read and write")

(check (= [(cons 1 2) setFirst: 77] 77)
       "set! macro dispatches %self-slot target to slot-set!")

;;; define-constructor

(define-class DefConstructorMeep (Object) (foo bar))
(define-constructor [DefConstructorMeep newWithFoo: foo bar: bar]
  (set! (%self-slot foo) foo)
  (set! (%self-slot bar) bar))
(let ((meep [DefConstructorMeep newWithFoo: 3 bar: 4]))
  (check (eq? (type-of meep) DefConstructorMeep)
         "define-constructor newWith... class method returns instance")
  (check (= (slot-ref meep 'foo) 3)
         "define-constructor newWith... initializes first slot")
  (check (= (slot-ref meep 'bar) 4)
         "define-constructor newWith... initializes second slot"))
(check (closure? [[DefConstructorMeep class] lookupSelector: :newWithFoo:bar:])
       "define-constructor installs newWith... class method")
(check (closure? [DefConstructorMeep lookupSelector: :initWithFoo:bar:])
       "define-constructor installs initWith... instance method")

(define-class DefConstructorNew (Object) (foo))
(define-constructor [DefConstructorNew newFoo: foo]
  (set! (%self-slot foo) foo))
(let ((value [DefConstructorNew newFoo: 17]))
  (check (eq? (type-of value) DefConstructorNew)
         "define-constructor new... class method returns instance")
  (check (= (slot-ref value 'foo) 17)
         "define-constructor new... initializes slot"))
(check (closure? [DefConstructorNew lookupSelector: :initFoo:])
       "define-constructor installs init... instance method")

(define-class DefConstructorFrom (Object) (foo))
(define-constructor [DefConstructorFrom fromFoo: foo]
  (set! (%self-slot foo) foo))
(let ((value [DefConstructorFrom fromFoo: 42]))
  (check (eq? (type-of value) DefConstructorFrom)
         "define-constructor from... class method returns instance")
  (check (= (slot-ref value 'foo) 42)
         "define-constructor from... initializes slot"))
(check (closure? [DefConstructorFrom lookupSelector: :initFromFoo:])
       "define-constructor installs initFrom... instance method")

;;; Rectangle example

(define-class DefRectangle (Object) (width height))
(define-method [[DefRectangle class] width: w height: h]
  (let ((inst [self alloc]))
    (slot-set! inst 'width w)
    (slot-set! inst 'height h)
    inst))
(define-method [DefRectangle area]
  (* (%self-slot width) (%self-slot height)))
(check (= [[DefRectangle width: 4 height: 5] area] 20)
       "rectangle define-class/define-method example")

;;; super send

(define-class DefParent (Object) ())
(define-class DefChild (DefParent) ())
(define-method [DefParent answer] 11)
(define-method [DefChild answer] [ListTalk:super answer])
(check (= [(make-instance DefChild) answer] 11)
       "send macro rewrites super receiver to super send")

;;; macro special form

(check (macro? (macro (lambda (x) x))) "macro special form creates macro value")
(check (= ((macro (lambda (x) x)) (+ 1 2)) 3) "macro expansion is evaluated")

(define x-for-macro 42)
(define-macro (id-macro x) x)
(check (= (id-macro x-for-macro) 42) "macro expansion evaluates in caller environment")

;;; while special form

(let ((n 0)
      (sum 0))
  (ListTalk-implementation:%while (< n 5)
    (set! sum (+ sum n))
    (set! n (+ n 1)))
  (check (= sum 10) "%while evaluates body while condition is truthy"))

(let ((ran #false))
  (check (null? (ListTalk-implementation:%while #false
                 (set! ran #true)))
         "%while returns nil when condition becomes false")
  (check (not ran) "%while skips body when condition is false"))

(check-raises "%while expects body"
  (ListTalk-implementation:%while #false))

(let ((break :outer-break)
      (continue :outer-continue))
  (ListTalk-implementation:%while #false
    (set! break :inner-break)
    (set! continue :inner-continue))
  (check (eq? break :outer-break) "%while does not bind break")
  (check (eq? continue :outer-continue) "%while does not bind continue"))

;;; while macro

(let ((n 0)
      (sum 0))
  (check (not (while (< n 5)
                (set! sum (+ sum n))
                (set! n (+ n 1))))
         "while returns false when condition becomes false")
  (check (= sum 10) "while evaluates body while condition is truthy"))

(check (while #true (break)) "while break without value returns true")
(check (= (while #true (break 42)) 42) "while break returns value")
(check (equal? (while #true (break 1 2 3)) '(1 2 3))
       "while break returns multiple values as list")

(let ((n 0)
      (seen '()))
  (while (< n 5)
    (set! n (+ n 1))
    (if (= n 3)
        (continue))
    (set! seen (cons n seen)))
  (check (equal? seen '(5 4 2 1)) "while continue skips remaining body"))

(let ((n 0)
      (body-runs 0))
  (while (begin
           (set! n (+ n 1))
           (if (< n 3)
               (continue)
               (< n 5)))
    (set! body-runs (+ body-runs 1)))
  (check (= n 5) "while condition can use continue")
  (check (= body-runs 2) "while continue in condition skips body"))

;;; fold-expression and macroexpand

(check (= (fold-expression '(+ 1 2 3) (get-current-environment)) 6)
       "fold-expression constant-folds pure primitive application")

(check (environment? (get-current-environment))
       "get-current-environment returns environment")

(check (= (eval '(+ 20 22) (get-current-environment)) 42)
       "eval evaluates form in explicit environment")

(let ((eval-local 17))
  (check (= (eval 'eval-local (get-current-environment)) 17)
         "eval sees lexical environment bindings"))

(check (= (apply + '(10 20 12)) 42)
       "apply calls primitive with argument list")

(check (= (apply (lambda (x y) (+ x y)) '(19 23)) 42)
       "apply calls closure with argument list")

(define-macro (test-macroexpand-mac x) (list '+ x 1))
(let ((expanded (macroexpand '(test-macroexpand-mac 41) (get-current-environment))))
  (check (pair? expanded) "macroexpand returns pair")
  (check (eq? (car expanded) '+) "macroexpand expands to application"))

(let ((folded (fold-expression '`(,(test-macroexpand-mac 41)) (get-current-environment))))
  (check (special-form? [folded car])
         "fold-expression resolves quasiquote operator to special form")
  (check (equal? [[folded cdr] car] '((unquote 42)))
         "fold-expression recurses into quasiquote unquote"))

;;; Load tests

(load! :test-module-foo)
(check (= loaded-from-foo 42) "load! loads module into environment")
(check (pair? (memq :test-module-foo ListTalk:%modules)) "provide records loaded module")

(define saved-resolvers ListTalk:module-resolvers)
(load! :test-module-bar "/nonexistent-extra-path")
(check (= loaded-from-bar 91) "load! uses call-local resolvers")
(check (eq? saved-resolvers ListTalk:module-resolvers)
       "load! call-local resolvers do not mutate module-resolvers")

(check (primitive? ListTalk-OS:exit) "load! loads native module primitive")
(check (pair? (memq :os ListTalk:%modules)) "native module records provided module")

;;; catch / throw / unwind-protect / handler-bind

(check (= (catch :t (+ 1 2)) 3) "catch returns body value when no throw happens")
(check (= (catch :t (throw :t 42) 99) 42) "throw transfers control to matching catch")
(check (= (catch :outer (catch :inner (throw :outer 7))) 7)
       "throw skips non-matching inner catch")

(define unwind-x 0)
(check (= (unwind-protect 7 (set! unwind-x 1)) 7)
       "unwind-protect returns protected value on normal path")
(check (= unwind-x 1) "unwind-protect runs cleanup on normal path")

(define unwind-y 0)
(check (= (catch :t (unwind-protect (throw :t 9) (set! unwind-y 1))) 9)
       "unwind-protect rethrows and outer catch receives value")
(check (= unwind-y 1) "unwind-protect runs cleanup during throw")

(let ((c (catch :t
           (handler-bind (lambda (cond) (throw :t cond))
             (error "boom")))))
  (check (equal? (slot-ref c 'message) "boom")
         "handler-bind catches error condition with correct message"))

;;; Symbol package slot

(check (not (null? (slot-ref 'eval-test-alpha 'package)))
       "symbol package slot exposes package object")
(check (eq? ['eval-test-alpha package] (slot-ref 'eval-test-alpha 'package))
       "Symbol>>package returns package object")
(check (null? [[Symbol gensym] package])
       "Symbol>>package returns nil for uninterned symbol")
(check [:eval-test-keyword keyword?] "Symbol>>keyword? true for keyword symbol")
(check (not ['eval-test-alpha keyword?])
       "Symbol>>keyword? false for non-keyword symbol")
(check ['eval-test-alpha nameStartsWith?: "eval"]
       "Symbol>>nameStartsWith?: accepts prefix")
(check (not ['eval-test-alpha nameStartsWith?: "alpha"])
       "Symbol>>nameStartsWith?: rejects non-prefix")
(check-error-message "Readonly slot" "symbol package slot is readonly"
  (slot-set! 'eval-test-alpha 'package 1))

;;; Numeric abstract classes

(check (class? ComplexNumber) "ComplexNumber class is bound")
(check (class? Integer) "Integer class is bound")
(check (class? RationalNumber) "RationalNumber class is bound")
(check (class? RealNumber) "RealNumber class is bound")

;;; Report results

(if (> test-failures 0)
    (begin
      (display (string-append (number->string test-failures)
                              " eval test(s) failed"))
      (ListTalk-OS:exit 1))
    (display "eval tests passed"))
